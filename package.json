{
  "name": "claude-collab",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "bun run runtime:start",
    "dev": "bun run runtime:dev",
    "runtime:start": "cd packages/runtime && bun run start",
    "runtime:dev": "cd packages/runtime && bun run dev",
    "runtime:test": "cd packages/runtime && bun test",
    "coordination:start": "cd packages/coordination && bun run start",
    "coordination:dev": "cd packages/coordination && bun run dev",
    "coordination:test": "cd packages/coordination && bun test"
  }
}
