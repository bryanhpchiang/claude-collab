{
  "name": "@jam/runtime",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun run web:build && bun run src/index.ts",
    "dev": "bun run web:build && bun run src/index.ts",
    "test": "bun test",
    "web:dev": "bun ../../node_modules/vite/bin/vite.js",
    "web:build": "bun run ./scripts/build-web.ts",
    "web:test": "bun x vitest run -c vitest.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "bun-pty": "^0.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shared": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.8.8",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.2",
    "vite": "5.4.14",
    "vitest": "2.1.9"
  }
}
